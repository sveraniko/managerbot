# ManagerBot OPS1 environment contract (pilot bootstrap)
# Copy to `.env` and replace placeholder values.

# --- Required: manager/customer bot surfaces ---
MANAGERBOT_BOT_TOKEN=123456:replace-with-managerbot-token
MANAGERBOT_CUSTOMER_BOT_TOKEN=123456:replace-with-customer-delivery-token

# --- Required: direct TradeFlow backbone connectivity (shared infra) ---
# ManagerBot connects directly to existing TradeFlow Postgres + Redis.
MANAGERBOT_POSTGRES_DSN=postgresql+asyncpg://tradeflow_user:tradeflow_pass@tradeflow-postgres:5432/tradeflow
MANAGERBOT_REDIS_DSN=redis://tradeflow-redis:6379/0

# --- Optional: runtime tuning ---
MANAGERBOT_LOG_LEVEL=INFO
MANAGERBOT_QUEUE_PAGE_SIZE=5
MANAGERBOT_NOTIFICATION_POLL_SECONDS=20
MANAGERBOT_NOTIFICATION_DEDUPE_TTL_SECONDS=3600

# --- Optional: AI root + subfeatures ---
MANAGERBOT_AI_ENABLED=false
MANAGERBOT_AI_READER_ENABLED=false
MANAGERBOT_AI_RECOMMENDER_ENABLED=false
MANAGERBOT_AI_API_KEY=
MANAGERBOT_AI_BASE_URL=https://api.openai.com/v1
MANAGERBOT_AI_MODEL=gpt-4.1-mini
MANAGERBOT_AI_READER_PROMPT_VERSION=mb7c-reader-v1
MANAGERBOT_AI_RECOMMENDER_PROMPT_VERSION=mb7c-recommender-v1
MANAGERBOT_AI_TIMEOUT_SECONDS=12.0
MANAGERBOT_AI_MAX_INPUT_CHARS=6000
MANAGERBOT_AI_MAX_THREAD_ENTRIES=6
MANAGERBOT_AI_MAX_INTERNAL_NOTES=3
MANAGERBOT_AI_MAX_OUTPUT_TOKENS=500
MANAGERBOT_AI_INCLUDE_INTERNAL_NOTES=true
MANAGERBOT_AI_RECOMMENDER_MAX_OUTPUT_TOKENS=700
MANAGERBOT_AI_CACHE_TTL_SECONDS=120
MANAGERBOT_AI_MIN_CONFIDENCE_FOR_DRAFT_ADOPTION_WARNING=0.65

# --- Optional: internal handoff targets (Telegram group/chat IDs) ---
MANAGERBOT_HANDOFF_PRODUCTION_CHAT_ID=
MANAGERBOT_HANDOFF_WAREHOUSE_CHAT_ID=
MANAGERBOT_HANDOFF_ACCOUNTANT_CHAT_ID=
